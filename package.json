{
  "name": "@jinhee/laboratory",
  "version": "1.0.0",
  "private": true,
  "description": "Mini projects monorepo for research and experiments",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "check-types": "turbo check-types",
    "test": "turbo test",
    "clean": "turbo clean && rm -rf node_modules .turbo",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json}\"",
    "ci": "pnpm run format:check && pnpm run lint && pnpm run check-types && pnpm run test && pnpm run build",
    "admin": "turbo dev --filter=admin-lab",
    "admin:build": "turbo build --filter=admin-lab",
    "storybook": "pnpm --filter storybook dev",
    "storybook:build": "pnpm --filter storybook build"
  },
  "keywords": [
    "monorepo",
    "turborepo",
    "mini-projects"
  ],
  "author": "bebusl",
  "license": "ISC",
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.50.0",
    "@typescript-eslint/parser": "^8.50.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "prettier": "^3.0.0",
    "turbo": "^2.6.2",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@10.24.0",
  "dependencies": {
    "react": "^19.2.1",
    "react-dom": "^19.2.1"
  }
}
